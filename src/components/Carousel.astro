---
import { Image } from 'astro:assets';

interface Props {
  images: (ImageMetadata | string)[];
  alts?: string[];
  captions?: string[];
}

const { images, alts = [], captions = [] } = Astro.props;
const id = `carousel-${Math.random().toString(36).slice(2, 9)}`;
const hasCaptions = captions.some(c => c);
---

<figure class="carousel" data-carousel id={id}>
  <div class="carousel__track" aria-live="polite">
    {images.map((img, i) => (
      <div class="carousel__slide" aria-label={`Slide ${i + 1} of ${images.length}`}>
        {typeof img === 'string' ? (
          <video
            src={img}
            class="carousel__img"
            autoplay
            loop
            muted
            playsinline
          />
        ) : (
          <Image
            src={img}
            alt={alts[i] ?? ''}
            class="carousel__img"
            loading={i === 0 ? 'eager' : 'lazy'}
          />
        )}
      </div>
    ))}
  </div>

  {hasCaptions && (
    <div class="carousel__caption-area">
      {images.map((_, i) => (
        <p
          class={`carousel__caption-text${i === 0 ? ' is-active' : ''}`}
          data-caption-index={i}
        >
          {captions[i] || '\u00A0'}
        </p>
      ))}
    </div>
  )}

  {images.length > 1 && (
    <div class="carousel__controls">
      <button class="carousel__btn" aria-label="Previous slide" data-prev>
        <svg width="10" height="10" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="carousel__dots" role="tablist" aria-label="Slides">
        {images.map((_, i) => (
          <button
            class="carousel__dot"
            role="tab"
            aria-label={`Go to slide ${i + 1}`}
            aria-selected={i === 0 ? 'true' : 'false'}
            data-index={i}
          />
        ))}
      </div>

      <button class="carousel__btn" aria-label="Next slide" data-next>
        <svg width="10" height="10" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  )}
</figure>

<script>
  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach((carousel) => {
    const track = carousel.querySelector<HTMLElement>('.carousel__track')!;
    const slides = carousel.querySelectorAll<HTMLElement>('.carousel__slide');
    const dots = carousel.querySelectorAll<HTMLButtonElement>('.carousel__dot');
    const captions = carousel.querySelectorAll<HTMLElement>('.carousel__caption-text');
    const prevBtn = carousel.querySelector<HTMLButtonElement>('[data-prev]');
    const nextBtn = carousel.querySelector<HTMLButtonElement>('[data-next]');
    const total = slides.length;
    let current = 0;

    function goTo(index: number) {
      current = (index + total) % total;
      track.scrollTo({ left: current * track.offsetWidth, behavior: 'smooth' });
      dots.forEach((dot, i) => dot.setAttribute('aria-selected', String(i === current)));
      captions.forEach((cap, i) => cap.classList.toggle('is-active', i === current));
    }

    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((dot) => dot.addEventListener('click', () => goTo(Number(dot.dataset.index))));

    // Sync on scroll snap (e.g. swipe)
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const index = Array.from(slides).indexOf(entry.target as HTMLElement);
            if (index !== -1) {
              current = index;
              dots.forEach((dot, i) => dot.setAttribute('aria-selected', String(i === current)));
              captions.forEach((cap, i) => cap.classList.toggle('is-active', i === current));
            }
          }
        });
      },
      { root: track, threshold: 0.6 }
    );
    slides.forEach((slide) => observer.observe(slide));
  });
</script>

<style>
  .carousel {
    margin: 0;
    width: 100%;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    box-shadow:
      0 0 1px rgba(0, 0, 0, 0.05),
      0 1px 1px rgba(0, 0, 0, 0.08),
      0 2px 2px rgba(0, 0, 0, 0.08),
      0 4px 4px rgba(0, 0, 0, 0.08);
  }

  /* Track */
  .carousel__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .carousel__track::-webkit-scrollbar {
    display: none;
  }

  .carousel__slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .carousel__img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Caption area */
  .carousel__caption-area {
    position: relative;
    padding: 12px 16px;
    border-top: 1px solid var(--color-border);
  }

  .carousel__caption-text {
    margin: 0 auto;
    max-width: 728px;
    font-size: 12px;
    font-weight: 400;
    line-height: 16px;
    letter-spacing: 0.01em;
    color: var(--color-text);
    white-space: pre-line;
    display: none;
  }

  .carousel__caption-text.is-active {
    display: block;
  }

  /* Controls bar */
  .carousel__controls {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    border-top: 1px solid var(--color-border);
  }

  /* Prev / Next buttons */
  .carousel__btn {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    border-radius: 50%;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .carousel__btn:hover {
    border-color: var(--color-text-muted);
    color: var(--color-text);
  }

  /* Dots */
  .carousel__dots {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .carousel__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.25);
    padding: 0;
    cursor: pointer;
    transition: background 0.15s ease, transform 0.15s ease;
  }

  .carousel__dot[aria-selected="true"] {
    background: #ffffff;
    transform: scale(1.3);
  }
</style>
