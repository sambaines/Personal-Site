---
import pattern from '../../images/primary-button-pattern.svg'
import { Icon } from 'astro-icon/components'

interface Props {
    href?: string;
    type?: "button" | "submit" | "reset";
    disabled?: boolean;
    class?: string;
    icon?: string;
    iconPosition?: "leading" | "trailing";
    [key: string]: unknown;
}

const { href, type = "button", disabled = false, class: className, icon, iconPosition = 'trailing', ...rest } = Astro.props;
const isLink = href !== undefined && href !== "";


/**
 * Button component usage examples:
 *
 * Link:
 * <Button href="/blog/my-post">Read more</Button>
 *
 * Action buttons:
 * <Button type="button">Add to cart</Button>
 * <Button type="submit">Submit</Button>
 * <Button disabled>Loading…</Button>
 *
 * With extra attributes:
 * <Button href="/external" target="_blank" rel="noopener noreferrer">External</Button>
 * <Button aria-label="Add item to cart">Add to cart</Button>
 */

---
<style>
    .button-wrapper {
        position: relative;
        width: 100%;
        height: 54px;
        padding: 3px;
    }
    .primary {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: #1A2023;
        color: #EDE9DE;
        height: 48px;
        width: 100%;
        padding: 13px 54px 16px;
        clip-path: polygon(20px 0, calc(100% - 20px) 0, 100% 50%, calc(100% - 20px) 100%, 20px 100%, 0% 50%);
        border: none;
        font: inherit;
        cursor: pointer;
        text-decoration: none;
        box-sizing: border-box;
        position: relative;
        z-index: 2;
    }
    .primary:disabled {
        cursor: not-allowed;
        opacity: 0.6;
    }
    .button-outline {
        display: block;
        position: absolute;
        top: 0;
        left: -1px;
        pointer-events: none;
        width: calc(100% + 2px);
        background: #A35139;
        height: 54px;
        padding: 3px 4px;
        clip-path: polygon(23px 0px,calc(100% - 23px) 0,100% 50%,calc(100% - 23px) 100%,23px 100%,0% 50%);
        mask: linear-gradient(#000 1.1px,transparent 1.1px calc(100% - 1.1px),#000 calc(100% - 1.1px)),
        linear-gradient(50deg,#000 18.5px,transparent 18.5px),
        linear-gradient(-50deg,#000 18.5px,transparent 18.5px),
        linear-gradient(130deg,#000 18.5px,transparent 18.5px),
        linear-gradient(-130deg,#000 18.5px,transparent 18.5px);
        mask-composite: add;
        z-index: 1;
    }
    .button-focus-ring {
        display: block;
        position: absolute;
        top: -2px;
        left: -3.5px;
        pointer-events: none;
        width: calc(100% + 7px);
        background: #ab2061;
        height: 58px;
        padding: 3px 4px;
        clip-path: polygon(24px 0,calc(100% - 24px) 0,calc(100% + 0.5px) 50%,calc(100% - 24px) 100%, 24px 100%, -0.5px 50%);
        mask: linear-gradient(#000 1px,transparent 1px calc(100% - 1px),#000 calc(100% - 1px)),
        linear-gradient(50deg,#000 19.5px,transparent 19.5px),
        linear-gradient(-50deg,#000 19.5px,transparent 19.5px),
        linear-gradient(130deg,#000 19.5px,transparent 19.5px),
        linear-gradient(-130deg,#000 19.5px,transparent 19.5px);
        mask-composite: add;
        transform: scale(0.9);
        opacity: 0;
        z-index: 0;
    }
    .primary:focus {
        outline: none;
        transition: none;
    }
    .primary:focus ~ .button-focus-ring, .primary:focus-visible ~ .button-focus-ring {
        transform: scale(1);
        opacity: 1;
        transition: all 200ms cubic-bezier(0.25, 0, 0.4, 1);
    }
    .primary > img {
        position: absolute;
        left: 2px;
        top: 1.5px;
        opacity: 0.2;
    }
    .primary > img:last-child {
        transform: scaleX(-1);
        left: calc(100% - 53px);
    }

    .primary:hover > img, .primary:focus > img, .primary:active > img {
        opacity: 1;
        transition: opacity 150ms ease-in-out;
    }
    .button-icon-leading {
        margin-right: var(--framework-8);
    }
    .button-icon-trailing {
        margin-left: var(--framework-8);
    }
</style>

<div class="button-wrapper">
    {isLink ? (
        <a href={href} class:list={["primary", className]} {...rest}>
            <img src={pattern.src} width={51} height={45} />
            {icon && iconPosition !== 'trailing' && <Icon name={icon} size={20} class="button-icon-leading" />}
            <slot>Click Me</slot>
            {icon && iconPosition === 'trailing' && <Icon name={icon} size={20} class="button-icon-trailing" />}
            <img src={pattern.src} width={51} height={45} />
        </a>
    ) : (
        <button type={type} disabled={disabled} class:list={["primary", className]} {...rest}>
            <img src={pattern.src} width={51} height={45} />
            {icon && iconPosition !== 'trailing' && <Icon name={icon} size={20} class="button-icon-leading" />}
            <slot>Click Me</slot>
            {icon && iconPosition === 'trailing' && <Icon name={icon} size={20} class="button-icon-trailing" />}
            <img src={pattern.src} width={51} height={45} />
        </button>
    )}
    <div class="button-outline" aria-hidden="true" />
    <div class="button-focus-ring" aria-hidden="true" />
</div>