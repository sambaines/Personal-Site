---
import arrowIconRaw from '../icons/arrow-icon.svg?raw';

interface Props {
  title: string;
  label: string;
  backHref?: string;
}

const { title, label, backHref = '/' } = Astro.props;
---

<a href={backHref} class="title-bar">
  <div class="title-bar__left">
    <div class="title-bar__back" aria-hidden="true">
      <span class="title-bar__back-icon" set:html={arrowIconRaw} />
      <span class="title-bar__back-text">Back to Case Studies</span>
    </div>
    <span class="title-bar__title">{title}</span>
  </div>
  <span class="title-bar__label">{label}</span>
</a>

<style>
  .title-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    max-width: 728px;
    padding: 16px 24px;
    border-radius: 48px;
    border: 0.5px solid #212121;
    background: #151717;
    box-shadow:
      0 4px 4px 0 rgba(0, 0, 0, 0.08),
      0 2px 2px 0 rgba(0, 0, 0, 0.08),
      0 1px 1px 0 rgba(0, 0, 0, 0.08),
      0 0 1px 0 rgba(0, 0, 0, 0.08),
      inset 0 1px 0.5px 0 rgba(255, 255, 255, 0.04),
      0 0 1.5px 0 rgba(0, 0, 0, 0.12),
      inset 0 1px 0 0 rgba(255, 255, 255, 0.04);
    text-decoration: none;
    cursor: pointer;
  }

  .title-bar__left {
    display: flex;
    align-items: center;
    min-width: 0;
  }

  .title-bar__back {
    display: flex;
    align-items: center;
    gap: 4px;
    white-space: nowrap;
    overflow: hidden;
    max-width: 0;
    opacity: 0;
    padding-right: 0;
    transition:
      max-width 0.3s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.2s ease,
      padding-right 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .title-bar:hover .title-bar__back {
    max-width: 240px;
    opacity: 1;
    padding-right: 32px;
  }

  .title-bar__back-icon {
    display: flex;
    flex-shrink: 0;
    transform: rotate(180deg);
  }

  .title-bar__back-icon :global(svg) {
    width: 16px;
    height: 16px;
  }

  .title-bar__back-text {
    font-size: 16px;
    font-weight: 500;
    line-height: 24px;
    letter-spacing: 0.03em;
    color: var(--color-text);
  }

  .title-bar__title {
    font-size: 16px;
    font-weight: 500;
    line-height: 24px;
    letter-spacing: 0.03em;
    color: var(--color-text);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .title-bar__label {
    font-size: 16px;
    font-weight: 400;
    line-height: 24px;
    letter-spacing: 0.03em;
    color: var(--color-text-muted);
    white-space: nowrap;
    flex-shrink: 0;
    margin-left: 16px;
  }
</style>
