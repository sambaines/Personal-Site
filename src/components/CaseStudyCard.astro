---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import metricIconRaw from '../icons/metric-icon.svg?raw';
import roleIconRaw from '../icons/role-icon.svg?raw';
import scopeIconRaw from '../icons/scope-icon.svg?raw';

interface Props {
  entry: CollectionEntry<'case-studies'>;
}

const { entry } = Astro.props;
const { title, company, companyLogo, cardDescription, metric, role, scope, cardImage } = entry.data;
const href = `/case-studies/${entry.id}`;
---

<article class="card">
  <a href={href} class="card__link" aria-label={`View case study: ${title} — ${company}`}></a>
  <div class="card__left">
    <header class="card__company">
      <img src={companyLogo.src} alt="" aria-hidden="true" class="card__logo" />
      <span class="card__company-name">{company}</span>
    </header>

    <div class="card__description" set:html={cardDescription} />

    <footer class="card__meta">
      <div class="card__meta-item">
        <span class="card__icon" aria-hidden="true" set:html={metricIconRaw} />
        <span>{metric}</span>
      </div>
      <div class="card__meta-item">
        <span class="card__icon" aria-hidden="true" set:html={roleIconRaw} />
        <span>{role}</span>
      </div>
      <div class="card__meta-item">
        <span class="card__icon" aria-hidden="true" set:html={scopeIconRaw} />
        <span>{scope}</span>
      </div>
    </footer>
  </div>

  <div class="card__image-wrap" aria-hidden="true">
    <Image src={cardImage} alt="" class="card__image" />
  </div>
</article>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 24px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 24px;
    overflow: hidden;
    box-shadow:
      0 0 1px rgba(0, 0, 0, 0.05),
      0 1px 1px rgba(0, 0, 0, 0.08),
      0 2px 2px rgba(0, 0, 0, 0.08),
      0 4px 4px rgba(0, 0, 0, 0.08);
    transition: border-color 200ms ease-out;
  }

  .card::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(73.69% 101.47% at 36.47% 100%, rgba(0, 188, 220, 0.12) 13.07%, rgba(40, 42, 42, 0.00) 100%);
    opacity: 0;
    transition: opacity 200ms ease-out;
    pointer-events: none;
    transition: opacity 200ms ease-out;
  }

  .card:has(.card__link:hover)::after {
    opacity: 1;
  }
  .card:has(.card__link:hover),
  .card:has(.card__link:focus-visible) {
    border-color: color-mix(in srgb, var(--color-border) 88%, var(--color-text-muted));
  }

  .card__link {
    position: absolute;
    inset: 0;
    border-radius: inherit;
  }

  .card__link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }

  .card__left {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  @media (min-width: 768px) {
    .card {
      flex-direction: row;
      gap: 2rem;
    }

    .card__left {
      flex: 0 0 360px;
    }
  }

  .card__company {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-block-end: 20px;
  }

  .card__logo {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .card__company-name {
    font-size: 16px;
    line-height: 24px;
    font-weight: 400;
    color: var(--color-text);
  }

  .card__description {
    flex: 1;
    font-size: 20px;
    line-height: 24px;
    color: var(--color-text-muted);
    margin-block-end: 24px;
  }

  .card__description :global(strong) {
    color: var(--color-text);
    font-weight: 400;
  }

  .card__meta {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-block-start: auto;
  }

  .card__meta-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 16px;
    line-height: 24px;
  }

  .card__icon {
    display: flex;
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    color: var(--color-text-muted);
  }

  .card__icon :global(svg) {
    width: 24px;
    height: 24px;
  }

  .card__image-wrap {
    flex: 1;
    overflow: hidden;
    border-radius: 8px;
    min-width: 0;
  }

  .card__image {
    width: 100%;
    height: auto;
    display: block;
  }
</style>
