---
import BaseLayout from "../layouts/BaseLayout.astro";
import CaseStudyCard from "../components/CaseStudyCard.astro";
import Hello from "../components/Hello.astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import arrowIcon from "../icons/arrow-icon.svg?raw";
import experimentsLandscape from "../images/experiments-landscape.png";

const caseStudies = (await getCollection('case-studies'))
  .sort((a, b) => a.data.order - b.data.order);

const allExperiments = await getCollection('experiments');
const latestExperiment = allExperiments.sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
)[0];

const { Content } = latestExperiment ? await render(latestExperiment) : { Content: null };
---

<BaseLayout title="Sam Baines — Product Designer">
  <section class="hero">
    <div class="hero__inner">
      <Hello />
      <h1>
        I design user-focused products that help people, that scale and are high on craft.
      </h1>
    </div>
  </section>

  <section class="case-studies" aria-label="Case studies">
    {caseStudies.map(entry => <CaseStudyCard entry={entry} />)}
  </section>

  <section class="bio" aria-label="About">
    <p>As a designer, I thrive in <span class="highlight">ambiguous problem spaces</span>, bringing <span class="highlight">clarity and strong product strategy</span> to start-ups and large organisations. I opt for <span class="highlight">shipping and learning about users early</span>, adding polish when the time is right.</p>
    <p>I'm drawn to companies that have a commitment to <span class="highlight">great craft and design leadership</span>, whilst allowing for <span class="highlight">continuous growth and learning opportunities</span> across their teams.</p>
  </section>

  {latestExperiment && Content && (
    <section class="experiments" aria-label="Latest experiment">
      <div class="experiments-header">
        <h2>Latest Experiment</h2>
        <hr />
        <a href="/experiments" class="view-all">View all <Fragment set:html={arrowIcon} /></a>
        <Image src={experimentsLandscape} alt="" aria-hidden="true" class="experiments-thumbnail" width={228} height={92} />
      </div>
      <div class="experiment-card">
        <Content />
      </div>
      <p class="experiment-description">
        {latestExperiment.data.description}
      </p>
      <p class="experiments-blurb"><span class="highlight">Experiments</span> are small <span class="highlight">UI explorations and interactions</span> that serve as a way for learning more about <span class="highlight">design =&gt; code</span> workflows, utilising AI where possible.</p>
    </section>
  )}
</BaseLayout>

<style>
  .hero {
    padding-inline: var(--page-padding-inline);
    padding-block-start: 40px;
    padding-block-end: clamp(32px, 5vw, 64px);
  }

  .hero__inner {
    max-width: 1024px;
    margin-inline: auto;
  }

  .hero h1 {
    margin-block-start: clamp(32px, 6vw, 80px);
    font-size: clamp(2rem, 3.5vw + 0.75rem, 4rem);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.01em;
    text-align: left;
    text-wrap: pretty;
    padding-right: clamp(1rem, 2vw, 2rem);
    padding-left: clamp(1rem, 2vw + 1rem, 2rem + 2.5rem);
  }

  .case-studies {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding-inline: var(--page-padding-inline);
    padding-block-end: clamp(3rem, 7vw, 6.25rem);
  }

  .case-studies > :global(article) {
    max-width: var(--content-max-width);
    margin-inline: auto;
    width: 100%;
  }

  /* ── Bio ── */

  .bio {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-inline: var(--page-padding-inline);
    padding-block-start: 8px;
    padding-block-end: clamp(3rem, 7vw, 6.25rem);
  }

  .bio p {
    max-width: var(--text-max-width);
    margin-inline: auto;
    width: 100%;
    font-size: clamp(1.5rem, 2vw, 2.25rem);
    line-height: 1.2;
    letter-spacing: 1%;
    color: var(--color-text-muted);
    font-weight: 500;
    text-wrap: pretty;
    padding-right: clamp(1rem, 2vw, 2rem);
    padding-left: clamp(1rem, 2vw, 2rem);
  }

  .bio .highlight {
    color: var(--color-text);
  }

  /* ── Experiments ── */

  .experiments {
    padding-inline: var(--page-padding-inline);
    padding-block-end: clamp(3rem, 7vw, 6.25rem);
  }

  .experiments-header {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    max-width: 800px;
    margin-inline: auto;
    margin-block-end: 40px;
  }

  .experiments-header h2 {
    width: 100%;
    font-size: 36px;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 1%;
    color: var(--color-text);
    white-space: nowrap;
  }

  @media (min-width: 640px) {
    .experiments-header {
      flex-wrap: nowrap;
    }

    .experiments-header h2 {
      width: auto;
    }
  }

  .experiments-header hr {
    flex: 1;
    padding-left: 0.5rem;
    padding-right: 0.5rem;
    border: none;
    border-top: 1px solid #FF8FED;
  }

  .experiments-header .view-all {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 16px;
    line-height: 24px;
    letter-spacing: 3%;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.15s ease;
  }

  .experiments-header:hover .view-all {
    color: var(--color-text);
  }

  .experiments-header .view-all :global(svg) {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .experiments-header .view-all :global(svg path) {
    fill: currentColor;
  }

  .experiments-thumbnail {
    width: 62px;
    height: 24px;
    object-fit: cover;
    border-radius: 4px;
    flex-shrink: 0;
    filter: grayscale(1);
  }
  .experiments-header:hover .experiments-thumbnail {
    filter: grayscale(0);
  }

  .experiment-card {
    max-width: 728px;
    margin-inline: auto;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding-block: clamp(1rem, 5vw, 3rem);
    padding-inline: clamp(1rem, 5vw, 3rem);
    overflow: hidden;
  }

  .experiment-card :global(.experiment-placeholder) {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 240px;
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .experiment-description {
    max-width: 728px;
    margin-inline: auto;
    margin-block-start: 1.5rem;
    font-size: 1rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    padding-right: clamp(1rem, 2vw, 2rem);
    padding-left: clamp(1rem, 2vw, 2rem);
  }

  .experiments-blurb {
    max-width: 728px;
    margin-inline: auto;
    width: 100%;
    margin-block-start: 3rem;
    font-size: clamp(1.25rem, 2vw, 1.75rem);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: 0.01em;
    color: var(--color-text-muted);
    text-wrap: pretty;
    padding-right: clamp(1rem, 2vw, 2rem);
    padding-left: clamp(1rem, 2vw, 2rem);
  }

  .experiments-blurb .highlight {
    color: var(--color-text);
  }
</style>
