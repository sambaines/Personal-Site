---
import "../styles/global.css";
import AgentationWidget from "../components/AgentationWidget.tsx";
import FloatingMenu from "../components/FloatingMenu.astro";

interface Props {
  title?: string;
}
const { title } = Astro.props;
const isDev = import.meta.env.DEV;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    {title && <title>{title}</title>}
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <main id="main" tabindex="-1">
      <slot />
    </main>
    <FloatingMenu />
    {isDev && <AgentationWidget client:only="react" />}
  </body>
</html>

<style>
  main {
    padding-block-end: calc(56px + max(16px, 2.5dvh) + env(safe-area-inset-bottom, 0px) + 24px);
  }
</style>
